# L9 Implementer Bot — environment configuration (copy to .env.local)

# Required
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/repo

# Ingestion / execution
PR_FIX_PAYLOAD_PATH=artifacts/agent_review_payload.json
PR_FIX_MODE=dry_run            # dry_run | propose_only | repair_and_verify | repair_verify_and_push | learn_only
PR_FIX_WRITE_CEILING=T1
PR_FIX_VERIFY_COMMAND=make agent-check
PR_FIX_OUTPUT_DIR=runtime/pr_repair
PR_FIX_MAX_PRS=5
PR_FIX_INCLUDE_DRAFTS=0

# Writes (gated; default off)
PR_FIX_POST_COMMENT=0
PR_FIX_ALLOW_PUSH=0            # requires PR_FIX_MODE=repair_verify_and_push

# LLM-Router bridge (default off = NullLLMClient, no network/keys)
PR_FIX_LLM_ENABLED=0
PR_FIX_LLM_APPLY=0
PR_FIX_LLM_CLIENT_ID=implementer-bot
PR_FIX_LLM_SHIM_PATH=router-shim/shim.mjs
PR_FIX_LLM_NODE_BIN=node

# Per-tool review actuation layer
PR_FIX_MATRIX_PATH=contracts/fix_matrix.yaml
PR_FIX_TOOL_COPILOT=1          # proven default lane
PR_FIX_TOOL_CODERABBIT=0
PR_FIX_TOOL_SONARCLOUD=0
PR_FIX_TOOL_GITGUARDIAN=0
