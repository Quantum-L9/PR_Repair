# Required
GITHUB_TOKEN=replace_me
GITHUB_REPOSITORY=owner/repo

# Optional
CODERABBIT_API_KEY=
CODECOV_API_KEY=
CODERABBIT_API_BASE_URL=
CODECOV_API_BASE_URL=https://api.codecov.io

# Pipeline controls
PR_FIX_MAX_PRS=5
PR_FIX_MODE=dry_run
PR_FIX_ALLOW_PUSH=0
PR_FIX_OUTPUT_DIR=runtime/pr_repair
PR_FIX_INCLUDE_DRAFTS=0
PR_FIX_WRITE_CEILING=T1
PR_FIX_VERIFY_COMMAND=make agent-check
